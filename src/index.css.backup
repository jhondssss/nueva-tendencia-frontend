@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  body { @apply bg-crema font-body text-cafe-950; font-size: 14px; line-height: 1.6; }

  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { @apply bg-crema-dark; }
  ::-webkit-scrollbar-thumb { @apply bg-cafe-300 rounded-full; }
  ::-webkit-scrollbar-thumb:hover { @apply bg-cafe-500; }
  ::selection { @apply bg-dorado-500/30 text-cafe-900; }
}

@layer components {
  .btn-primary {
    @apply inline-flex items-center gap-2 px-4 py-2 rounded
           bg-cafe-gradient text-white font-body font-medium text-sm
           transition-all duration-200 hover:shadow-glow-cafe hover:scale-[1.02]
           active:scale-[0.98] disabled:opacity-40 disabled:cursor-not-allowed;
  }
  .btn-secondary {
    @apply inline-flex items-center gap-2 px-4 py-2 rounded
           bg-white border border-surface-border text-cafe-800 font-body text-sm
           transition-all duration-200 hover:bg-crema-dark
           active:scale-[0.98] disabled:opacity-40 disabled:cursor-not-allowed;
  }
  .btn-ghost {
    @apply inline-flex items-center gap-2 px-3 py-2 rounded
           text-cafe-600 font-body text-sm transition-all duration-150
           hover:bg-crema-dark hover:text-cafe-900 active:scale-[0.97];
  }

  .card {
    @apply bg-white border border-surface-border rounded-lg shadow-card
           transition-all duration-200 hover:shadow-card-hover;
  }
  .card-flat { @apply bg-white border border-surface-border rounded-lg; }
  .kpi-card { @apply card p-5 flex flex-col gap-3; }

  .input {
    @apply w-full px-3 py-2 rounded bg-white border border-surface-border
           text-cafe-950 font-body text-sm placeholder:text-cafe-300
           transition-all duration-150 focus:outline-none
           focus:border-cafe-500 focus:ring-1 focus:ring-cafe-500/30
           disabled:opacity-50 disabled:cursor-not-allowed;
  }
  .input-error { @apply border-red-400 focus:border-red-400; }
  .label { @apply block text-xs font-medium text-cafe-700 mb-1.5 uppercase tracking-wider; }
  .select {
    @apply input appearance-none cursor-pointer;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%238B5E3C' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
    padding-right: 2.5rem;
  }

  .badge { @apply inline-flex items-center gap-1 px-2 py-0.5 rounded text-2xs font-medium uppercase tracking-wider; }
  .badge-pendiente { @apply bg-amber-100  text-amber-800  border border-amber-300; }
  .badge-cortado   { @apply bg-orange-100 text-orange-800 border border-orange-300; }
  .badge-aparado   { @apply bg-blue-100   text-blue-800   border border-blue-300; }
  .badge-solado    { @apply bg-purple-100 text-purple-800 border border-purple-300; }
  .badge-empaque   { @apply bg-teal-100  text-teal-800  border border-teal-300; }
  .badge-terminado { @apply bg-green-100 text-green-800 border border-green-300; }

  .table-container { @apply w-full overflow-x-auto; }
  .table { @apply w-full border-collapse; }
  .table thead tr { @apply border-b border-surface-border; }
  .table thead th { @apply px-4 py-3 text-left text-2xs font-medium text-cafe-500 uppercase tracking-widest whitespace-nowrap bg-crema; }
  .table tbody tr { @apply border-b border-crema-dark transition-colors duration-100 hover:bg-crema; }
  .table tbody td { @apply px-4 py-3 text-sm text-cafe-800; }

  .modal-overlay { @apply fixed inset-0 z-50 flex items-center justify-center p-4 bg-cafe-950/50 backdrop-blur-sm animate-fade-in; }
  .modal-panel { @apply bg-white border border-surface-border rounded-xl shadow-modal w-full max-h-[90vh] overflow-y-auto animate-slide-up; }

  .nav-item {
    @apply flex items-center gap-3 px-3 py-2.5 rounded text-cafe-200 text-sm font-medium
           transition-all duration-150 cursor-pointer hover:bg-cafe-800 hover:text-white;
  }
  .nav-item-active { @apply bg-cafe-800 text-white border-r-2 border-dorado-500; }

  .page-header { @apply flex items-center justify-between mb-6; }
  .page-title { @apply font-display text-2xl font-semibold text-cafe-950; }
  .page-subtitle { @apply text-sm text-cafe-500 mt-0.5; }

  .skeleton {
    @apply bg-crema-dark rounded;
    background: linear-gradient(90deg, #F0EBE4 25%, #E8DDD4 50%, #F0EBE4 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
}

@layer utilities {
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
}
